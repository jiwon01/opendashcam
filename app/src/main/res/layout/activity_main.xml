<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/leftOverlayPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:background="@drawable/bg_control_panel"
        android:gravity="end"
        android:layout_marginEnd="0dp"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/textRecordingStatus"
            android:layout_width="156dp"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:background="@drawable/bg_control_status"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="@string/label_recording_status_idle"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSettings"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="156dp"
            android:layout_height="44dp"
            android:layout_gravity="end"
            android:layout_marginTop="12dp"
            android:backgroundTint="#2EFFFFFF"
            android:text="@string/btn_open_settings"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRecord"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="156dp"
            android:layout_height="50dp"
            android:layout_gravity="end"
            android:layout_marginTop="10dp"
            android:backgroundTint="#1E88E5"
            android:text="@string/btn_start_recording"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRecordings"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="156dp"
            android:layout_height="44dp"
            android:layout_gravity="end"
            android:layout_marginTop="10dp"
            android:backgroundTint="#2EFFFFFF"
            android:text="@string/btn_open_recordings"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/footerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_footer_bar"
        android:gravity="center_vertical"
        android:minHeight="62dp"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/textWatermark"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            tools:text="2026.03.03 08:57:49  GPS 37.12345, 127.12345" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textGpsIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_footer_badge_default"
                android:paddingStart="9dp"
                android:paddingTop="3dp"
                android:paddingEnd="9dp"
                android:paddingBottom="3dp"
                android:text="@string/label_footer_gps"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textRecIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_footer_badge_default"
                android:paddingStart="9dp"
                android:paddingTop="3dp"
                android:paddingEnd="9dp"
                android:paddingBottom="3dp"
                android:text="@string/label_footer_rec"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
